//  MONGOOSE SCHEMA
// ─────────────────────────────────────────
const pendingCodeSchema = new mongoose.Schema({
    code:      { type: String, required: true },
    createdAt: { type: Date,   default: Date.now, expires: 3600 } // TTL 1 hour
});

const userSchema = new mongoose.Schema({
    discordId: { type: String, required: true, unique: true },

    xcloud: {
        username:     String,
        password:     String, // AES-256 encrypted
        accessToken:  String,
        refreshToken: String,
        lastLoginAt:  Date,
    },

    credits:       { type: Number, default: 0 },
    nextDeduction: Date,

    usage: {
        linksGeneratedToday: { type: Number, default: 0 },
        lastGenerateDate:    { type: String, default: '' }, // YYYY-MM-DD
        // The last un-redeemed pending link (code + shortened URL)
        pendingLink: {
            code:       String,
            shortUrl:   String,
            createdAt:  Date,
        },
    },

    autoDevice: {
        sessionId:  String,
        deviceName: String,
        isEnabled:  { type: Boolean, default: false },
    },

    pendingCodes: [pendingCodeSchema],
});

const User = mongoose.model('User', userSchema);

// ─────────────────────────────────────────
//  XCLOUD API HELPERS
// ─────────────────────────────────────────
const XCLOUD_HEADERS = {
    'Origin':          'https://app.xcloudphone.com',
    'Referer':         'https://app.xcloudphone.com/',
    'Accept':          'application/json',
    'Accept-Language': 'vi-VN',
    'User-Agent':      'Mozilla/5.0 (Linux; Android 10; K) AppleWebKit/537.36',
};

/** Parse renterAccessToken & renterRefreshToken from Set-Cookie header array */
function extractCookies(setCookieArray) {
    let accessToken = null, refreshToken = null;
    for (const cookie of (setCookieArray || [])) {
        const [kv] = cookie.split(';');
        const eqIdx = kv.indexOf('=');
        const k = kv.slice(0, eqIdx).trim();
        const v = kv.slice(eqIdx + 1).trim();
        if (k === 'renterAccessToken')  accessToken  = v;
        if (k === 'renterRefreshToken') refreshToken = v;
    }
    return { accessToken, refreshToken };
}

function cookieString(at, rt) {
    const parts = [];
    if (at) parts.push(`renterAccessToken=${at}`);
    if (rt) parts.push(`renterRefreshToken=${rt}`);
    return parts.join('; ');
}

/**
 * Login to XCloud. Returns { accessToken, refreshToken }.
 * Tokens come from Set-Cookie header.
 */
async function xcloudLogin(username, password) {
    const res = await axios.post(
        `${XCLOUD_API}/auth/renters/login`,
        { username, password, userDeviceId: crypto.randomUUID() },
        { headers: { ...XCLOUD_HEADERS, 'Content-Type': 'application/json' }, validateStatus: () => true }
    );

    if (res.status === 400 || res.status === 401) throw new Error('INVALID_CREDENTIALS');

    const { accessToken, refreshToken } = extractCookies(res.headers['set-cookie']);
    if (!accessToken || !refreshToken)  throw new Error('TOKEN_NOT_FOUND');

    return { accessToken, refreshToken };
}

/**
 * Fetch active rental sessions for a user.
 * Returns array of { sessionId, deviceName, remainingMs }
 * ALWAYS fetches fresh from API — never trusts cached device.
 */
async function xcloudGetSessions(accessToken) {
    const res = await axios.get(
        `${XCLOUD_API}/renters/rental-sessions?page=1&limit=20`,
        {
            headers: {
                ...XCLOUD_HEADERS,
                'Cookie': `renterAccessToken=${accessToken}`,
            },
            validateStatus: () => true,
        }
    );

    if (res.status === 401) throw new Error('TOKEN_EXPIRED');
    if (res.status !== 200) throw new Error(`GET_SESSIONS_${res.status}`);

    const raw = Array.isArray(res.data) ? res.data
        : (res.data?.data || res.data?.items || res.data?.rentalSessions || res.data?.result || []);

    return raw
        .filter(x => {
            const s = (x.status || x.rentalStatus || '').toLowerCase();
            return s !== 'expired' && s !== 'cancelled';
        })
        .map(x => {
            const sessionId   = x.id || x.sessionId || x.rentalSessionId;
            const deviceName  = x.deviceName || x.name || x.device?.name || x.device?.model || 'Unknown';
            let remainingMs   = 0;
            if (x.remainingTime   != null) remainingMs = x.remainingTime   * 1000;
            else if (x.remainingSeconds)   remainingMs = x.remainingSeconds * 1000;
            else if (x.remainingMinutes)   remainingMs = x.remainingMinutes * 60000;
            else {
                const exp = x.expiresAt || x.expiredAt || x.endTime || x.endAt;
                if (exp) remainingMs = new Date(exp).getTime() - Date.now();
            }
            return { sessionId, deviceName, remainingMs: Math.max(0, remainingMs) };
        });
}

/**
 * Safe decrypt — returns null instead of throwing if hash is missing/malformed.
 */
function safeDecrypt(hash) {
    if (!hash || !hash.includes(':')) return null;
    try { return decrypt(hash); } catch { return null; }
}

/**
 * Re-login using stored credentials. Throws 'NO_STORED_PASSWORD' if password not saved.
 */
async function reloginUser(user) {
    const password = safeDecrypt(user.xcloud?.password);
    if (!password) throw new Error('NO_STORED_PASSWORD');
    const tokens = await xcloudLogin(user.xcloud.username, password);
    user.xcloud.accessToken  = tokens.accessToken;
    user.xcloud.refreshToken = tokens.refreshToken;
    user.xcloud.lastLoginAt  = new Date();
    await user.save();
    return tokens.accessToken;
}

/** Extend a rental session by `hours` hours. */
async function xcloudExtend(accessToken, sessionId, hours = 1) {
    const res = await axios.post(
        `${XCLOUD_API}/rentals/extend`,
        { listSessionId: [sessionId], rentalHours: hours },
        {
            headers: {
                ...XCLOUD_HEADERS,
                'Content-Type': 'application/json',
                'Cookie': `renterAccessToken=${accessToken}`,
            },
            validateStatus: () => true,
        }
    );
    if (res.status === 401) throw new Error('TOKEN_EXPIRED');
    if (res.status !== 200 && res.status !== 201) throw new Error(`EXTEND_${res.status}`);
    return res.data;
}

// ─────────────────────────────────────────
//  LINK4M
// ─────────────────────────────────────────
async function shortenLink4m(url) {
    const res = await axios.get('https://link4m.co/api-shorten/v2', {
        params: { api: LINK4M_TOKEN, url },
        validateStatus: () => true,
    });
    if (res.data?.status === 'success') return res.data.shortenedUrl;
    throw new Error('LINK4M_FAILED');
}

