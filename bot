// ================= XCLOUD API =================
const API = 'https://api.xcloudphone.com';
const HEADERS_BASE = {
    'Origin': 'https://app.xcloudphone.com',
    'Referer': 'https://app.xcloudphone.com/',
    'Accept': 'application/json',
    'Accept-Language': 'vi-VN',
    'User-Agent': 'Mozilla/5.0 (Linux; Android 10; K) AppleWebKit/537.36',
};

function makeCookie(at, rt) {
    const parts = [];
    if (at) parts.push(`renterAccessToken=${at}`);
    if (rt) parts.push(`renterRefreshToken=${rt}`);
    return parts.join('; ');
}

function extractCookies(setCookieArray) {
    let accessToken = null, refreshToken = null;
    for (const cookie of setCookieArray || []) {
        const [kv] = cookie.split(';');
        const [k, v] = kv.trim().split('=');
        if (k === 'renterAccessToken') accessToken = v;
        if (k === 'renterRefreshToken') refreshToken = v;
    }
    return { accessToken, refreshToken };
}

function parseJWT(token) {
    try {
        const b = token.split('.')[1];
        const padded = b + '='.repeat((4 - b.length % 4) % 4);
        return JSON.parse(Buffer.from(padded, 'base64').toString('utf8'));
    } catch { return null; }
}

function tokenExpiresIn(token) {
    const p = parseJWT(token);
    if (!p?.exp) return null;
    return p.exp * 1000 - Date.now(); // ms
}

// ── Login ──
async function loginXcloud(username, password) {
    const userDeviceId = crypto.randomUUID();
    const res = await axios.post(
        `${API}/auth/renters/login`,
        { username, password, userDeviceId },
        { headers: HEADERS_BASE, validateStatus: () => true }
    );

    if (res.status === 400 || res.status === 401) throw new Error('INVALID_CREDENTIALS');

    const cookies = res.headers['set-cookie'];
    const { accessToken, refreshToken } = extractCookies(cookies);

    // Một số server trả token trong body thay vì cookie
    const at = accessToken || res.data?.accessToken || res.data?.data?.accessToken;
    const rt = refreshToken || res.data?.refreshToken || res.data?.data?.refreshToken;

    if (!at || !rt) throw new Error('TOKEN_NOT_FOUND');
    return { accessToken: at, refreshToken: rt };
}

// ── Refresh token ──
async function refreshAccessToken(user) {
    const rt = user.xcloud?.refreshToken;
    if (!rt) throw new Error('NO_REFRESH_TOKEN');

    const endpoints = [
        '/auth/refresh',
        '/auth/renters/refresh',
        '/renters/refresh',
        '/auth/refresh-token',
    ];

    for (const path of endpoints) {
        try {
            const res = await axios.post(`${API}${path}`,
                { refreshToken: rt },
                {
                    headers: {
                        ...HEADERS_BASE,
                        'Content-Type': 'application/json',
                        'Cookie': makeCookie(null, rt),
                    },
                    validateStatus: () => true
                }
            );

            // Lấy token từ body
            const na = res.data?.accessToken || res.data?.renterAccessToken || res.data?.data?.accessToken;
            if (na) {
                user.xcloud.accessToken = na;
                await user.save();
                return na;
            }

            // Lấy từ Set-Cookie
            const { accessToken } = extractCookies(res.headers['set-cookie']);
            if (accessToken) {
                user.xcloud.accessToken = accessToken;
                await user.save();
                return accessToken;
            }
        } catch {}
    }

    // Fallback: re-login nếu có username/password
    if (user.xcloudUsername && user.xcloudPassword) {
        const password = decrypt(user.xcloudPassword);
        const { accessToken, refreshToken } = await loginXcloud(user.xcloudUsername, password);
        user.xcloud = { accessToken, refreshToken };
        user.lastLoginAt = new Date();
        await user.save();
        return accessToken;
    }

    throw new Error('REFRESH_FAILED');
}

// ── Ensure valid access token ──
async function ensureToken(user) {
    const at = user.xcloud?.accessToken;
    if (!at) return await refreshAccessToken(user);

    const msLeft = tokenExpiresIn(at);
    if (msLeft !== null && msLeft < 3 * 60 * 1000) {
        return await refreshAccessToken(user);
    }
    return at;
}

// ── Get rental sessions ──
async function getRentalSessions(user) {
    const at = await ensureToken(user);
    const rt = user.xcloud?.refreshToken;

    const paths = [
        '/renters/rental-sessions?page=1&limit=50&sortBy=startTime&sortOrder=desc',
        '/rentals',
    ];

    for (const path of paths) {
        try {
            const res = await axios.get(`${API}${path}`, {
                headers: {
                    ...HEADERS_BASE,
                    'Cookie': makeCookie(at, rt),
                },
                validateStatus: () => true
            });

            if (res.status === 401) {
                // Retry after refresh
                const newAt = await refreshAccessToken(user);
                const res2 = await axios.get(`${API}${path}`, {
                    headers: { ...HEADERS_BASE, 'Cookie': makeCookie(newAt, rt) },
                    validateStatus: () => true
                });
                if (res2.status !== 200) continue;
                return normalizeSessions(res2.data);
            }

            if (res.status !== 200) continue;
            return normalizeSessions(res.data);
        } catch {}
    }

    throw new Error('CANNOT_FETCH_SESSIONS');
}

function normalizeSessions(data) {
    const raw = Array.isArray(data) ? data
        : (data?.data || data?.items || data?.rentals || data?.rentalSessions || data?.result || []);

    return raw
        .filter(x => {
            const s = x.status || x.rentalStatus || '';
            return s !== 'expired' && s !== 'cancelled';
        })
        .map(x => {
            const sessionId = x.id || x.sessionId || x.rentalSessionId || x.rentalId;
            const name = x.deviceName || x.name || x.device?.name || x.device?.model || x.phoneName || 'Unknown';
            let remainingMs = 0;
            if (x.remainingTime != null) remainingMs = x.remainingTime * 1000;
            else if (x.remainingSeconds) remainingMs = x.remainingSeconds * 1000;
            else if (x.remainingMinutes) remainingMs = x.remainingMinutes * 60000;
            else {
                const exp = x.expiresAt || x.expiredAt || x.endTime || x.endAt;
                if (exp) remainingMs = new Date(exp).getTime() - Date.now();
            }
            return { sessionId, name, remainingMs: Math.max(0, remainingMs) };
        });
}

// ── Renew session ──
async function renewSession(user, sessionId, hours = 1) {
    const at = await ensureToken(user);
    const rt = user.xcloud?.refreshToken;

    const res = await axios.post(`${API}/rentals/extend`,
        { listSessionId: [sessionId], rentalHours: hours },
        {
            headers: {
                ...HEADERS_BASE,
                'Content-Type': 'application/json',
                'Cookie': makeCookie(at, rt),
            },
            validateStatus: () => true
        }
    );

    if (res.status === 401) {
        await refreshAccessToken(user);
        const newAt = user.xcloud.accessToken;
        const res2 = await axios.post(`${API}/rentals/extend`,
            { listSessionId: [sessionId], rentalHours: hours },
            { headers: { ...HEADERS_BASE, 'Content-Type': 'application/json', 'Cookie': makeCookie(newAt, rt) }, validateStatus: () => true }
        );
        if (res2.status !== 200 && res2.status !== 201) throw new Error(`HTTP ${res2.status}`);
        return res2.data;
    }

    if (res.status !== 200 && res.status !== 201) throw new Error(`HTTP ${res.status}`);
    return res.data;
}

// ── Auto relogin every 5 days ──
async function autoReloginIfNeeded(user) {
    const FIVE_DAYS = 5 * 24 * 60 * 60 * 1000;
    if (!user.lastLoginAt) return;
    if (Date.now() - user.lastLoginAt.getTime() < FIVE_DAYS) return;
    if (!user.xcloudUsername || !user.xcloudPassword) return;

    try {
        const password = decrypt(user.xcloudPassword);
        const { accessToken, refreshToken } = await loginXcloud(user.xcloudUsername, password);
        user.xcloud = { accessToken, refreshToken };
        user.lastLoginAt = new Date();
        await user.save();
        console.log(`[AutoRelogin] ${user.discordId} OK`);
    } catch (err) {
        if (err.message === 'INVALID_CREDENTIALS') {
            user.autoRenew.enabled = false;
            await user.save();
            try {
                const u = await client.users.fetch(user.discordId);
                await u.send('⚠️ Tài khoản XCloud không còn hợp lệ. Vui lòng dùng `/config` để cập nhật lại.');
            } catch {}
        } else throw err;
    }
}

// ================= WORKER =================
async function autoRenewWorker() {
    const users = await User.find({ 'autoRenew.enabled': true });
    console.log(`[Worker] Checking ${users.length} users...`);

    for (const user of users) {
        try {
            await autoReloginIfNeeded(user);

            const sessions = await getRentalSessions(user);
            const thresh = user.autoRenew.thresholdHours;
            const addHours = user.autoRenew.renewHours;

            // Lọc session cần gia hạn
            const toRenew = sessions.filter(s => {
                const withinThresh = s.remainingMs > 0 && s.remainingMs / 3600000 <= thresh;
                // Nếu có danh sách sessionIds cụ thể thì chỉ gia hạn những cái đó
                if (user.autoRenew.sessionIds?.length > 0) {
                    return withinThresh && user.autoRenew.sessionIds.includes(s.sessionId);
                }
                return withinThresh;
            });

            if (!toRenew.length) continue;

            const results = [];
            for (const s of toRenew) {
                try {
                    await renewSession(user, s.sessionId, addHours);
                    results.push(`✅ **${s.name}** +${addHours}h`);
                    user.autoRenew.totalRenewed++;
                } catch (e) {
                    results.push(`❌ **${s.name}**: ${e.message}`);
                }
            }

            user.autoRenew.lastRenewedAt = new Date();
            user.autoRenew.lastError = null;
            await user.save();

            // Notify user
            try {
                const discordUser = await client.users.fetch(user.discordId);
                const embed = new EmbedBuilder()
                    .setColor(0x5b6af5)
                    .setTitle('☁ XCloud AutoRenew')
                    .setDescription(results.join('\n'))
                    .setFooter({ text: `Tổng đã gia hạn: ${user.autoRenew.totalRenewed} lần` })
                    .setTimestamp();
                await discordUser.send({ embeds: [embed] });
            } catch {}

        } catch (err) {
            console.error(`[Worker] Error for ${user.discordId}:`, err.message);
            user.autoRenew.lastError = err.message;
            await user.save();

            try {
                const owner = await client.users.fetch(OWNER_ID);
                await owner.send(`⚠️ Worker error (${user.discordId}):\n\`\`\`${err.stack}\`\`\``);
            } catch {}
        }
    }
}

// ================= EMBEDS =================
function embedSuccess(title, desc) {
    return new EmbedBuilder().setColor(0x23d18b).setTitle(`✅ ${title}`).setDescription(desc).setTimestamp();
}
function embedError(title, desc) {
    return new EmbedBuilder().setColor(0xff5e5e).setTitle(`❌ ${title}`).setDescription(desc).setTimestamp();
}
function embedInfo(title, desc) {
    return new EmbedBuilder().setColor(0x5b6af5).setTitle(`☁ ${title}`).setDescription(desc).setTimestamp();
}
function fmtMs(ms) {
    if (ms <= 0) return '⛔ Hết hạn';
    const h = Math.floor(ms / 3600000), m = Math.floor((ms % 3600000) / 60000);
    if (h > 4) return `🟢 ${h}g ${m}p`;
    if (h >= 1) return `🟡 ${h}g ${m}p`;
    return `🔴 ${m}p`;
}

// ================= COMMANDS =================
client.on('interactionCreate', async interaction => {
    if (!interaction.isChatInputCommand()) return;

    const safeRun = async (fn) => {
        try {
            await fn();
        } catch (err) {
            console.error(`[CMD:${interaction.commandName}]`, err);
            const msg = { embeds: [embedError('Lỗi', 'Có lỗi xảy ra. Vui lòng thử lại.')], ephemeral: true };
            if (interaction.deferred || interaction.replied) {
                await interaction.editReply(msg).catch(() => {});
            } else {
                await interaction.reply(msg).catch(() => {});
            }
            try {
                const owner = await client.users.fetch(OWNER_ID);
                await owner.send(`❗ CMD Error [${interaction.commandName}]:\n\`\`\`${err.stack?.slice(0, 1500)}\`\`\``);
            } catch {}
        }
    };

    let user = await User.findOne({ discordId: interaction.user.id });
    if (!user) user = await User.create({ discordId: interaction.user.id });

    // ── /config ──
    if (interaction.commandName === 'config') {
        await safeRun(async () => {
            await interaction.deferReply({ ephemeral: true });
            const username = interaction.options.getString('username');
            const password = interaction.options.getString('password');

            const { accessToken, refreshToken } = await loginXcloud(username, password);

            user.xcloudUsername = username;
            user.xcloudPassword = encrypt(password);
            user.xcloud = { accessToken, refreshToken };
            user.lastLoginAt = new Date();
            await user.save();

            await interaction.editReply({
                embeds: [embedSuccess('Đăng nhập thành công', `Tài khoản \`${username}\` đã được lưu.\nToken sẽ tự động làm mới.`)]
            });
        });
    }

    // ── /devices ──
    else if (interaction.commandName === 'devices') {
        await safeRun(async () => {
            await interaction.deferReply({ ephemeral: true });
            if (!user.xcloud?.accessToken) {
                return interaction.editReply({ embeds: [embedError('Chưa đăng nhập', 'Dùng `/config` để đăng nhập trước.')] });
            }

            const sessions = await getRentalSessions(user);
            if (!sessions.length) {
                return interaction.editReply({ embeds: [embedInfo('Thiết bị', 'Không có thiết bị đang thuê.')] });
            }

            const lines = sessions.map((s, i) =>
                `**${i + 1}.** ${s.name}\n> ${fmtMs(s.remainingMs)}\n> \`${s.sessionId}\``
            );

            await interaction.editReply({
                embeds: [embedInfo(`Thiết bị (${sessions.length})`, lines.join('\n\n'))]
            });
        });
    }

    // ── /renew ──
    else if (interaction.commandName === 'renew') {
        await safeRun(async () => {
            await interaction.deferReply({ ephemeral: true });
            if (!user.xcloud?.accessToken) {
                return interaction.editReply({ embeds: [embedError('Chưa đăng nhập', 'Dùng `/config` trước.')] });
            }

            const hours = interaction.options.getInteger('hours') || 1;
            const sessions = await getRentalSessions(user);

            if (!sessions.length) {
                return interaction.editReply({ embeds: [embedInfo('Gia hạn', 'Không có thiết bị nào.')] });
            }

            const results = [];
            for (const s of sessions) {
                try {
                    await renewSession(user, s.sessionId, hours);
                    results.push(`✅ **${s.name}** +${hours}h`);
                    user.autoRenew.totalRenewed++;
                } catch (e) {
                    results.push(`❌ **${s.name}**: ${e.message}`);
                }
            }
            await user.save();

            await interaction.editReply({
                embeds: [embedInfo('Kết quả gia hạn', results.join('\n'))]
            });
        });
    }

    // ── /auto ──
    else if (interaction.commandName === 'auto') {
        await safeRun(async () => {
            await interaction.deferReply({ ephemeral: true });
            if (!user.xcloud?.accessToken) {
                return interaction.editReply({ embeds: [embedError('Chưa đăng nhập', 'Dùng `/config` trước.')] });
            }

            const sub = interaction.options.getSubcommand();

            if (sub === 'on') {
                const thresh = interaction.options.getNumber('threshold') || RENEW_THRESHOLD_HOURS;
                const hours = interaction.options.getInteger('hours') || RENEW_ADD_HOURS;
                user.autoRenew.enabled = true;
                user.autoRenew.thresholdHours = thresh;
                user.autoRenew.renewHours = hours;
                await user.save();
                await interaction.editReply({
                    embeds: [embedSuccess('Auto Renew BẬT', `Ngưỡng: **${thresh}h** | Gia hạn: **+${hours}h**\nBot sẽ tự gia hạn khi thiết bị còn dưới ${thresh} giờ.`)]
                });
            }

            else if (sub === 'off') {
                user.autoRenew.enabled = false;
                await user.save();
                await interaction.editReply({
                    embeds: [embedInfo('Auto Renew TẮT', 'Đã tắt tự động gia hạn.')]
                });
            }

            else if (sub === 'status') {
                const ar = user.autoRenew;
                const statusStr = ar.enabled ? '🟢 **BẬT**' : '🔴 **TẮT**';
                const lastRenew = ar.lastRenewedAt ? `<t:${Math.floor(ar.lastRenewedAt.getTime() / 1000)}:R>` : 'Chưa có';
                const lastErr = ar.lastError ? `\n⚠️ Lỗi cuối: \`${ar.lastError}\`` : '';

                await interaction.editReply({
                    embeds: [embedInfo('Trạng thái Auto Renew',
                        `Trạng thái: ${statusStr}\n` +
                        `Ngưỡng: **${ar.thresholdHours}h** | Gia hạn thêm: **+${ar.renewHours}h**\n` +
                        `Tổng đã gia hạn: **${ar.totalRenewed}** lần\n` +
                        `Lần cuối: ${lastRenew}${lastErr}`
                    )]
                });
            }
        });
    }

    // ── /status ──
    else if (interaction.commandName === 'status') {
        await safeRun(async () => {
            await interaction.deferReply({ ephemeral: true });
            if (!user.xcloud?.accessToken) {
                return interaction.editReply({ embeds: [embedError('Chưa đăng nhập', 'Dùng `/config` trước.')] });
            }

            const at = user.xcloud.accessToken;
            const rt = user.xcloud.refreshToken;
            const atMs = tokenExpiresIn(at);
            const rtMs = rt ? tokenExpiresIn(rt) : null;

            function fmtToken(ms) {
                if (ms === null) return '❓ Không rõ';
                if (ms <= 0) return '🔴 Hết hạn';
                const m = Math.floor(ms / 60000), h = Math.floor(m / 60), d = Math.floor(h / 24);
                if (d > 0) return `🟢 ${d} ngày ${h % 24}g`;
                if (h > 0) return `🟡 ${h}g ${m % 60}p`;
                return `🔴 ${m}p`;
            }

            await interaction.editReply({
                embeds: [embedInfo('Trạng thái tài khoản',
                    `Tài khoản: \`${user.xcloudUsername || 'Chưa rõ'}\`\n` +
                    `Access Token: ${fmtToken(atMs)}\n` +
                    `Refresh Token: ${fmtToken(rtMs)}\n` +
                    `Auto Renew: ${user.autoRenew.enabled ? '🟢 BẬT' : '🔴 TẮT'}`
                )]
            });
        });
    }
});

