async function registerCommands() {
    const rest = new REST({ version: '10' }).setToken(process.env.DISCORD_TOKEN);

    const commands = [
        {
            name:        'login',
            description: 'Authenticate your XCloud account.',
        },
        {
            name:        'get',
            description: 'Obtain resources.',
            options: [{
                name:        'credit',
                description: 'Generate a link to earn 1 credit (max 5 per day).',
                type:        1,
            }],
        },
        {
            name:        'redeem',
            description: 'Redeem a credit code.',
            options: [
                { name: 'code', description: 'The code to redeem (e.g. XC-A1B2C3)', type: 3, required: true },
            ],
        },
        {
            name:        'devices',
            description: 'View your active rental devices and select one for auto-renew.',
        },
        {
            name:        'profile',
            description: 'View your account profile, credits, and auto-renew status.',
        },
        {
            name:        'add',
            description: '[ADMIN] Add credits to a user.',
            options: [
                { name: 'user',   description: 'Target user',      type: 6, required: true },
                { name: 'amount', description: 'Credits to add',   type: 4, required: true },
            ],
        },
        {
            name:        'reset',
            description: '[ADMIN] Reset a user credits to 0.',
            options: [
                { name: 'user', description: 'Target user', type: 6, required: true },
            ],
        },
    ];

    try {
        console.log('[CMD] Registering slash commands...');
        await rest.put(
            Routes.applicationCommands(process.env.CLIENT_ID),
            { body: commands }
        );
        console.log('[CMD] All commands registered.');
    } catch (err) {
        console.error('[CMD] Registration failed:', err);
    }
}

