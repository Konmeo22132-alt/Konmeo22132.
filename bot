    const rest = new REST({ version: '10' }).setToken(process.env.DISCORD_TOKEN);

    const commands = [
        {
            name: 'config',
            description: 'Đăng nhập tài khoản XCloud',
            options: [
                { name: 'username', description: 'Tên đăng nhập', type: 3, required: true },
                { name: 'password', description: 'Mật khẩu', type: 3, required: true },
            ]
        },
        {
            name: 'devices',
            description: 'Xem danh sách thiết bị đang thuê',
        },
        {
            name: 'renew',
            description: 'Gia hạn tất cả thiết bị ngay',
            options: [
                { name: 'hours', description: 'Số giờ gia hạn (mặc định 1)', type: 4, required: false }
            ]
        },
        {
            name: 'auto',
            description: 'Quản lý tự động gia hạn',
            options: [
                {
                    name: 'on',
                    description: 'Bật auto renew',
                    type: 1, // SUB_COMMAND
                    options: [
                        { name: 'threshold', description: 'Gia hạn khi còn dưới X giờ (mặc định 4)', type: 10, required: false },
                        { name: 'hours', description: 'Số giờ gia hạn mỗi lần (mặc định 1)', type: 4, required: false },
                    ]
                },
                {
                    name: 'off',
                    description: 'Tắt auto renew',
                    type: 1,
                },
                {
                    name: 'status',
                    description: 'Xem trạng thái auto renew',
                    type: 1,
                },
            ]
        },
        {
            name: 'status',
            description: 'Xem trạng thái token và tài khoản',
        },
    ];

    try {
        console.log('[CMD] Registering slash commands...');
        await rest.put(
            Routes.applicationCommands(process.env.CLIENT_ID),
            { body: commands }
        );
        console.log('[CMD] Registered OK');
    } catch (err) {
        console.error('[CMD] Register failed:', err);
    }
}

